# TTS 推論服務 image（MeloTTS）。build context 為專案根（COPY tts-service/...）。容器內埠 9002。
# 較重（PyTorch）。分步安裝：web 相依 → CPU 版 torch → GitHub 安裝 MeloTTS → 下載字典/語料。
FROM python:3.11-slim

WORKDIR /app

# git 供 pip 從 GitHub 安裝 MeloTTS；build-essential 供部分套件編譯
RUN apt-get update && apt-get install -y --no-install-recommends \
        git build-essential && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY tts-service/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# CPU 版 torch + torchaudio（務必一起裝、同一 CPU 索引，版本才匹配且不含 CUDA）
# 只裝 torch、讓 MeloTTS 自己抓 torchaudio 會拉到 CUDA 版 → libcudart.so 缺庫，故在此一起釘。
RUN pip install --no-cache-dir torch torchaudio --index-url https://download.pytorch.org/whl/cpu

# MeloTTS 本體（GitHub）
RUN pip install --no-cache-dir git+https://github.com/myshell-ai/MeloTTS.git

# MeloTTS import 時會用到的日文字典（ZH 用不到但相依會 import）與英文 G2P 語料（NLTK），先在 build 準備好
RUN python -m unidic download && \
    python -c "import nltk; nltk.download('averaged_perceptron_tagger_eng'); nltk.download('cmudict')"

COPY tts-service/ /app/tts-service/

WORKDIR /app/tts-service

EXPOSE 9002

CMD ["python", "api.py"]
