# 後端「應用層」環境變數範本。複製成 backend/.env（不進版控）。
# 給 backend 程式（config.py）讀；容器對外 port / labels 走「部署層」的根目錄 .env。
# 說明見 reference/backend/backend-conventions.md §5。

APP_ENV=dev

# ── 資料庫（見 database.md）：初期 sqlite，換 postgres 只改這行 ──
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg://user:pass@db-host:5432/appdb

# 注意：本專案「有前端」，LLM provider 走「設定頁註冊多個、存 DB」（見 llm-integration.md §5），
# 因此這裡不設 LLM_PROVIDER / LLM_MODEL；provider 由使用者在前端設定頁新增並選用。

# ── OCR 推論服務（M2，獨立容器）──
# 本機 dev：OCR 服務在本機 9001；容器部署時由 docker-compose 覆寫成 http://ocr:9001（走內網）。
OCR_BASE_URL=http://localhost:9001

# ── TTS 推論服務（M3，獨立容器）──
# 本機 dev：TTS 服務在本機 9002；容器部署時由 docker-compose 覆寫成 http://tts:9002（走內網）。
TTS_BASE_URL=http://localhost:9002

# ── 文生圖推論服務（M4，獨立容器）──
# 本機 dev：文生圖服務在本機 9003；容器部署時由 docker-compose 覆寫成 http://image:9003（走內網）。
IMAGE_BASE_URL=http://localhost:9003
