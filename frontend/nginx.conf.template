# 前端容器 nginx 設定【路由版・推薦】。掛在 /<APP_ROUTE>/ 底下，內外網共用同一份 build。
# 容器啟動時 nginx 官方 image 會用 envsubst 把 ${APP_ROUTE} 代換成環境變數值。
# ${APP_ROUTE} 必須與 build 時 VITE_BASE_PATH=/${APP_ROUTE}/ 一致，換 route 要重 build。
# 說明見 reference/frontend/frontend-backend-integration.md §6、deploy-guide.md 路由機制。

server {
    listen 80;
    server_name _;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml+rss image/svg+xml;

    # 直接打根路徑時導到 route（方便內網 http://<ip>:<port>/ 進來）
    location = / {
        return 302 /${APP_ROUTE}/;
    }

    # 前端 SPA，掛在 /<route>/；dist 實體檔在 html 根，靠 alias 對應
    location /${APP_ROUTE}/ {
        alias /usr/share/nginx/html/;
        try_files $uri $uri/ /${APP_ROUTE}/index.html;
    }

    # API：/<route>/api/ 反代到後端，並把前綴改回後端實際的 /api/
    location /${APP_ROUTE}/api/ {
        proxy_pass http://backend:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE / 串流（LLM 逐字輸出）必要
        proxy_buffering off;
        proxy_read_timeout 3600s;
    }
}
